# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.0

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=text-embedding-3-small

# ── Vector Store ─────────────────────────────────────────────────────────────
VECTORSTORE_PATH=data/vectorstore
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── RAG ──────────────────────────────────────────────────────────────────────
RETRIEVER_TOP_K=5

# ── LangSmith Tracing (optional) ────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=move-mind-ai
